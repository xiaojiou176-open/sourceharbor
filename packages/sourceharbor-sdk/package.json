{
  "name": "@sourceharbor/sdk",
  "version": "0.1.18",
  "description": "Thin public TypeScript SDK for the SourceHarbor HTTP API.",
  "homepage": "https://xiaojiou176-open.github.io/sourceharbor/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xiaojiou176-open/sourceharbor.git"
  },
  "bugs": {
    "url": "https://github.com/xiaojiou176-open/sourceharbor/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "sourceharbor",
    "sdk",
    "typescript",
    "mcp",
    "retrieval",
    "knowledge-pipeline"
  ],
	"scripts": {
		"build": "npx --yes -p typescript tsc -p tsconfig.build.json",
		"prepare": "npm run build",
		"typecheck": "npx --yes -p typescript tsc -p tsconfig.build.json --noEmit",
		"pack:dry": "npm pack --dry-run"
	}
}
